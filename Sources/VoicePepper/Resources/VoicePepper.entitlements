<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Microphone access -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Outbound network (for model download only) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Bluetooth access for BLE recording pen -->
    <key>com.apple.security.device.bluetooth</key>
    <true/>

    <!-- App Sandbox disabled for global hotkey support -->
    <!-- Note: Enable and use com.apple.security.temporary-exception.apple-events
         if submitting to Mac App Store. For direct distribution, Sandbox is off. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
